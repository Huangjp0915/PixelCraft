{
  "productName": "PixelCraft",
  "version": "1.0.0",
  "identifier": "com.pixelcraft.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PixelCraft - 像素画编辑器",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "Copyright © 2024 PixelCraft Team",
    "category": "Graphics and Design",
    "shortDescription": "A desktop pixel art converter and editor",
    "longDescription": "PixelCraft is a powerful desktop application for converting images to pixel art and editing them with advanced tools. Features include customizable resolution, color palette quantization, dithering, and a full-featured pixel editor.",
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.13",
      "exceptionDomain": "",
      "signingIdentity": null,
      "entitlements": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": {
        "template": null,
        "bannerPath": null,
        "dialogImagePath": null,
        "fipsCompliant": false
      }
    },
    "fileAssociations": [
      {
        "ext": ["pixproj"],
        "name": "PixelCraft Project",
        "description": "PixelCraft Project File",
        "role": "Editor"
      }
    ]
  },
  "plugins": {}
}
